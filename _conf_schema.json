{
  "fetch_mode": {
    "description": "命令文档获取模式",
    "type": "string",
    "options": [
      "metadata",
      "api"
    ],
    "hint": "metadata: 通过本地插件元数据生成；api: 通过 Dashboard API 获取。",
    "default": "metadata"
  },
  "output_mode": {
    "description": "帮助菜单输出模式",
    "type": "string",
    "options": [
      "text",
      "image"
    ],
    "hint": "text: 文本分页输出；image: 使用 HTML 模板渲染图片输出。",
    "default": "text"
  },
  "post_process_image": {
    "description": "后处理图片",
    "type": "bool",
    "hint": "仅在 output_mode=image 时生效；默认开启，自动裁剪主卡片外的透明/白色边缘（含右侧残留边）。",
    "default": true
  },
  "admin_name": {
    "description": "登录ASTR后台的用户名",
    "type": "string"
  },
  "admin_password": {
    "description": "登录ASTR后台的密码",
    "type": "string"
  },
  "ASTRHost": {
    "description": "ASTR 后台地址",
    "type": "string",
    "default": "http://127.0.0.1:6185"
  },
  "auto_clear_config_after_run": {
    "description": "运行后自动清空配置",
    "type": "bool",
    "default": false
  },
  "debug": {
    "description": "Debug Mode",
    "type": "bool",
    "default": false
  },
  "light_template": {
    "description": "浅色图片模板",
    "type": "string",
    "options": [
      "classic",
      "frost",
      "compact",
      "ember_industrial",
      "sakura"
    ],
    "hint": "仅当 output_mode=image 时生效；若填写非法值会自动回退为 classic。",
    "default": "classic"
  },
  "dark_template": {
    "description": "深色图片模板",
    "type": "string",
    "hint": "留空默认使用浅色同款深色版(自动追加 _dark)。"
  },
  "dark_time_start": {
    "description": "深色模式开始时间(北京时间)",
    "type": "string",
    "hint": "格式如 18:00",
    "default": "18:00"
  },
  "dark_time_end": {
    "description": "深色模式结束时间(北京时间)",
    "type": "string",
    "hint": "格式如 06:00",
    "default": "06:00"
  }
}
